<div class="screen">
  <div class="view view--quadrant">
    <div class="layout layout--col gap--small">
      <div class="flex flex--row flex--center-y gap--small mb--small">
        <span class="title title--small">{{ today_date }}</span>
        <div class="divider grow"></div>
      </div>
      <div class="flex flex--col gap--xsmall">
        {% if today_events.size > 0 %}
          {% for event in today_events limit: 4 %}
            <div class="item">
              <div class="meta"></div>
              <div class="content flex flex--row flex--center-y gap--medium">
                <span class="label label--small" style="min-width: 68px;">{{ event.time }}</span>
                <span class="description" data-clamp="1">{{ event.title }}</span>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <span class="description text--gray-50">No events</span>
        {% endif %}
      </div>
    </div>
  </div>
</div>
